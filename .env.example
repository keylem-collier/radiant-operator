# Core model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Vertex AI / Gemini / Veo (model IDs are hardcoded in src/lib/radiant/env.ts)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CREDENTIALS_JSON=
VEO_PROVIDER=studio

# LiveKit hackathon foundation
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=agent-py
LIVEKIT_PHONE_NUMBER=
LIVEKIT_REDEEM_CODE=

# Voice personality / TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Speech-to-text (AssemblyAI — server-side only, never expose in client)
ASSEMBLYAI_API_KEY=
# Optional: eu for EU data residency (default us)
ASSEMBLYAI_REGION=us

# Moss retrieval and memory (embedding model ID is hardcoded in env.ts)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=knowledge
MOSS_MEMORY_INDEX_NAME=memory

# Other hackathon sponsor candidates
TRUEFOUNDRY_API_KEY=
UNSILOED_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
MINIMAX_API_KEY=
QWEN_API_KEY=

# App/runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: .env.local is for local dev only. It is NOT deployed to Vercel.
# After filling .env.local, run: npm run vercel:env && npx vercel --prod --yes
